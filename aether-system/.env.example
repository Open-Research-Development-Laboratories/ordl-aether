# AETHER Environment Configuration
# Copy this file to .env and update the values

# Application
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=http://localhost:3000,http://127.0.0.1:3000,https://aether.ordl.org

# NASA API (get free key at https://api.nasa.gov)
NASA_API_KEY=DEMO_KEY

# Database
DATABASE_URL=sqlite:///./data/aether.db
VECTOR_DB_PATH=./data/vector_db

# AI Models
MODEL_CACHE_DIR=./ai_models/cache
PREWARM_MODELS=false

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379/0
